{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "32bit-garage",
  "buildCommand": "npm run build --prefix web/frontend",
  "devCommand": "npm start --prefix web/frontend",
  "installCommand": "npm install --prefix web/frontend",
  "outputDirectory": "web/frontend/build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
